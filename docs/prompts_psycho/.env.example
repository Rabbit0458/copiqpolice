# COP'IQ — Variables d'environnement du pipeline AI
# Copie ce fichier en `.env` et remplis les valeurs.
# NE COMMIT JAMAIS le fichier .env.

# ── Providers IA ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Modèles (overrides facultatifs) ─────────────────────────────────────────
# Si vide, le pipeline utilise des valeurs par défaut sensées.
OPENAI_MODEL=gpt-4o
DEEPSEEK_MODEL=deepseek-chat
ANTHROPIC_MODEL=claude-sonnet-4-5

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://nuoonagnkhbeeymtvrcn.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # service_role JAMAIS la anon key
